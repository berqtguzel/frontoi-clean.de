# Tenant API (Laravel ana proje). config:cache sonrası uygulama kodunda env() kullanılmaz — sadece buradan okunur.
OMR_API_BASE="https://omerdogan.de/api"
# Tenant JSON API sürümü (1 veya 2). PHP OmrConfig::apiUrl() ve cache için.
OMR_API_VERSION=2
OMR_API_TIMEOUT="10"
OMR_TENANT_ID=""
# OMR_TENANT_ID boşsa kullanılan yedek (isteğe bağlı)
OMR_TENANT_ID_FALLBACK="oi_clean_groupde_693fac5831392"
OMR_MAIN_TENANT=""
OMR_DEFAULT_LOCALE="de"
OMR_MENU_ENDPOINT="null"
DASHBOARD_API_URL="null"
DASHBOARD_API_KEY="null"
DASHBOARD_SITE_ID="null"
DASHBOARD_CACHE_TTL="3600"
VITE_REMOTE_API_BASE="null"
VITE_REMOTE_MENU_ENDPOINT="null"
VITE_REMOTE_TIMEOUT="10000"
VITE_REMOTE_TENANT_ID="null"
VITE_API_BASE_URL="null"
# Tarayıcı analytics (app.jsx); OMR_API_VERSION ile uyumlu tutun (v1 / v2).
VITE_OMR_API_BASE="https://omerdogan.de/api"
VITE_OMR_API_VERSION="v2"

VITE_TENANT_CITY=Baden-Württemberg
VITE_TENANT_DISTRICT=Baden-Württemberg
VITE_TENANT_STATE_CODE=DE-BW

# Merkez (Stuttgart civarı)
VITE_TENANT_CENTER_LNG=9.0000
VITE_TENANT_CENTER_LAT=48.5000

# Zoom (denge)
VITE_TENANT_SCALE_DESKTOP=7500
VITE_TENANT_SCALE_MOBILE=9500

